# Токен бота от @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token_here

# PostgreSQL
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/divers_data

# Прокси для доступа к Telegram API (если api.telegram.org заблокирован)
# Примеры:
# TELEGRAM_PROXY=socks5://127.0.0.1:1080
# TELEGRAM_PROXY=http://127.0.0.1:7890
TELEGRAM_PROXY=

# URL Web App для выбора точки на карте (HTTPS обязателен для Telegram)
# GitHub Pages:
# WEB_APP_URL=https://sanokpenok2.github.io/DiversData/
WEB_APP_URL=

# Лимиты защиты от спама
SPAM_MAX_MESSAGES_PER_MINUTE=20
SPAM_MAX_REPORTS_PER_DAY=10
SPAM_COOLDOWN_SECONDS=1
