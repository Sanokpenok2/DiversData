# Токен бота MAX (platform.max.ru → Чат-боты → Интеграция → Получить токен)
MAX_BOT_TOKEN=your_bot_token_here

# Базовый URL MAX Bot API
MAX_API_BASE_URL=https://platform-api2.max.ru/

# Webhook (production): URL и секрет для проверки заголовка X-Max-Bot-Api-Secret
# MAX_WEBHOOK_URL=
# MAX_WEBHOOK_SECRET=

# PostgreSQL
DATABASE_URL=postgres://postgres:password@127.0.0.1:5432/divers_data

# URL мини-приложения для выбора точки на карте (HTTPS)
# GitHub Pages:
# WEB_APP_URL=https://sanokpenok2.github.io/DiversData/
WEB_APP_URL=

# URL сайта для учёных (показывается дайверу в сообщении об успешном отчёте)
# SCIENTIST_WEB_URL=http://localhost:3000
SCIENTIST_WEB_URL=

# Лимиты защиты от спама
SPAM_MAX_MESSAGES_PER_MINUTE=20
SPAM_MAX_REPORTS_PER_DAY=10
SPAM_COOLDOWN_SECONDS=1
