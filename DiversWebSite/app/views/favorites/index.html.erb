<% content_for :title, "Избранное" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Избранные отчёты</h1>
    <%= link_to "Показать на карте", root_path(favorites_only: "1"), class: "btn btn-primary btn-sm" %>
  </div>

  <% if @reports.any? %>
    <div class="list-group favorites-list shadow-sm">
      <% @reports.each do |report| %>
        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-3 py-3">
          <div>
            <div class="fw-semibold">
              <%= link_to "Отчёт ##{report.id}", report_path(report), class: "text-decoration-none" %>
              <span class="badge badge-favorite ms-1"><i class="bi bi-star-fill"></i></span>
            </div>
            <div class="small text-muted">
              <%= report.observation_date.strftime("%d.%m.%Y") %> ·
              <%= report.encounter_label %> ·
              <%= report.depth_label %>
            </div>
            <div class="small mt-1"><%= report.coordinates_label %></div>
          </div>
          <div class="d-flex gap-2">
            <%= link_to "Открыть", report_path(report), class: "btn btn-outline-primary btn-sm" %>
            <%= button_to "Убрать", favorite_report_path(report), method: :delete, class: "btn btn-outline-secondary btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="report-card text-center py-5">
      <p class="text-muted mb-3">Пока нет избранных отчётов.</p>
      <%= link_to "Перейти к карте", root_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
