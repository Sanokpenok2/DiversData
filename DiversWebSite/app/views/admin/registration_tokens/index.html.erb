<% content_for :title, "Токены регистрации" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <h1 class="h3 mb-0">Токены регистрации</h1>
    <%= button_to "Создать токен", admin_registration_tokens_path, method: :post, class: "btn btn-primary btn-sm" %>
  </div>

  <div class="table-responsive report-card p-0">
    <table class="table table-hover mb-0">
      <thead class="table-light">
        <tr>
          <th>Токен</th>
          <th>Статус</th>
          <th>Создан</th>
          <th>Истекает</th>
          <th>Использован</th>
          <th></th>
        </tr>
      </thead>
      <tbody>
        <% @tokens.each do |token| %>
          <tr>
            <td><code class="token-chip"><%= token.token %></code></td>
            <td>
              <% if token.used_at? %>
                <span class="badge text-bg-secondary">Использован</span>
              <% elsif token.available? %>
                <span class="badge text-bg-success">Активен</span>
              <% else %>
                <span class="badge text-bg-danger">Истёк</span>
              <% end %>
            </td>
            <td class="small"><%= token.created_at.strftime("%d.%m.%Y %H:%M") %></td>
            <td class="small"><%= token.expires_at&.strftime("%d.%m.%Y") || "—" %></td>
            <td class="small"><%= token.used_by&.name || "—" %></td>
            <td class="text-end">
              <% unless token.used_at? %>
                <%= button_to "Удалить", admin_registration_token_path(token), method: :delete,
                              class: "btn btn-outline-danger btn-sm",
                              form: { data: { turbo_confirm: "Удалить токен?" } } %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  </div>
</div>
