<% content_for :title, "Отчёты по описанию" %>

<div class="container py-4">
  <div class="d-flex justify-content-between align-items-center mb-4">
    <div>
      <h1 class="h3 mb-1">Отчёты без точной геолокации</h1>
      <p class="text-muted mb-0">Место указано текстовым описанием в боте</p>
    </div>
    <%= link_to "← К карте", root_path, class: "btn btn-outline-secondary btn-sm" %>
  </div>

  <% if @reports.any? %>
    <div class="list-group favorites-list shadow-sm">
      <% @reports.each do |report| %>
        <div class="list-group-item list-group-item-action d-flex justify-content-between align-items-start gap-3 py-3">
          <div>
            <div class="fw-semibold">
              <%= link_to "Отчёт ##{report.id}", report_path(report), class: "text-decoration-none" %>
            </div>
            <div class="small text-muted">
              <%= report.observation_date.strftime("%d.%m.%Y") %> ·
              <%= report.reporter_name %> ·
              <%= report.encounter_label %> ·
              <%= report.depth_label %>
            </div>
            <div class="small mt-1 text-body-secondary"><%= report.location_description %></div>
          </div>
          <div class="d-flex gap-2 align-items-center">
            <% if report.photos.any? %>
              <span class="badge text-bg-light border"><i class="bi bi-image"></i> <%= report.photos.size %></span>
            <% end %>
            <%= link_to "Открыть", report_path(report), class: "btn btn-outline-primary btn-sm" %>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <div class="report-card text-center py-5">
      <p class="text-muted mb-3">Пока нет отчётов с текстовым описанием места.</p>
      <%= link_to "Перейти к карте", root_path, class: "btn btn-primary" %>
    </div>
  <% end %>
</div>
