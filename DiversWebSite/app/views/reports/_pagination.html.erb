<% pagination = local_assigns.fetch(:pagination) %>

<nav class="d-flex justify-content-between align-items-center flex-wrap gap-3 mt-4" aria-label="Навигация по страницам">
  <p class="text-muted small mb-0">
    Страница <%= pagination.page %> из <%= pagination.total_pages %>
  </p>

  <ul class="pagination pagination-sm mb-0">
    <li class="page-item <%= "disabled" if pagination.first_page? %>">
      <%= link_to "«", reports_index_path_with(page: 1), class: "page-link", aria: { label: "Первая страница" } %>
    </li>
    <li class="page-item <%= "disabled" if pagination.first_page? %>">
      <%= link_to "‹", reports_index_path_with(page: pagination.page - 1), class: "page-link", aria: { label: "Предыдущая страница" } %>
    </li>

    <% if pagination.page_window.first > 1 %>
      <li class="page-item">
        <%= link_to "1", reports_index_path_with(page: 1), class: "page-link" %>
      </li>
      <% if pagination.page_window.first > 2 %>
        <li class="page-item disabled"><span class="page-link">…</span></li>
      <% end %>
    <% end %>

    <% pagination.page_window.each do |page_number| %>
      <li class="page-item <%= "active" if page_number == pagination.page %>">
        <% if page_number == pagination.page %>
          <span class="page-link"><%= page_number %></span>
        <% else %>
          <%= link_to page_number, reports_index_path_with(page: page_number), class: "page-link" %>
        <% end %>
      </li>
    <% end %>

    <% if pagination.page_window.last < pagination.total_pages %>
      <% if pagination.page_window.last < pagination.total_pages - 1 %>
        <li class="page-item disabled"><span class="page-link">…</span></li>
      <% end %>
      <li class="page-item">
        <%= link_to pagination.total_pages, reports_index_path_with(page: pagination.total_pages), class: "page-link" %>
      </li>
    <% end %>

    <li class="page-item <%= "disabled" if pagination.last_page? %>">
      <%= link_to "›", reports_index_path_with(page: pagination.page + 1), class: "page-link", aria: { label: "Следующая страница" } %>
    </li>
    <li class="page-item <%= "disabled" if pagination.last_page? %>">
      <%= link_to "»", reports_index_path_with(page: pagination.total_pages), class: "page-link", aria: { label: "Последняя страница" } %>
    </li>
  </ul>
</nav>
