<!DOCTYPE html>
<html lang="ru">
  <head>
    <title><%= content_for(:title) || "DiversData — карта наблюдений" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" rel="stylesheet">
    <%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="site-body">
    <% if logged_in? %>
      <nav class="navbar navbar-expand-lg navbar-dark site-nav">
        <div class="container-fluid px-3 px-lg-4">
          <%= link_to "DiversData", root_path, class: "navbar-brand fw-semibold" %>
          <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#mainNav">
            <span class="navbar-toggler-icon"></span>
          </button>
          <div class="collapse navbar-collapse" id="mainNav">
            <ul class="navbar-nav me-auto mb-2 mb-lg-0">
              <li class="nav-item"><%= link_to "Карта", root_path, class: "nav-link #{'active' if controller_name == 'map'}" %></li>
              <li class="nav-item"><%= link_to "По описанию", descriptions_reports_path, class: "nav-link #{'active' if action_name == 'descriptions'}" %></li>
              <li class="nav-item"><%= link_to "Избранное", favorites_path, class: "nav-link #{'active' if controller_name == 'favorites'}" %></li>
              <% if admin? %>
                <li class="nav-item"><%= link_to "Удаления", admin_report_deletion_requests_path, class: "nav-link #{'active' if controller_name == 'report_deletion_requests'}" %></li>
                <li class="nav-item"><%= link_to "Токены", admin_registration_tokens_path, class: "nav-link" %></li>
                <li class="nav-item"><%= link_to "Пользователи", admin_scientists_path, class: "nav-link" %></li>
              <% end %>
            </ul>
            <form action="<%= report_lookup_path %>" method="get" class="d-flex gap-2 me-3" role="search">
              <input type="number" name="id" min="1" class="form-control form-control-sm" placeholder="№ отчёта" aria-label="Номер отчёта" required>
              <button type="submit" class="btn btn-light btn-sm text-nowrap">Найти</button>
            </form>
            <div class="d-flex align-items-center gap-3">
              <span class="text-white-50 small"><%= current_scientist.name %></span>
              <%= button_to "Выйти", logout_path, method: :delete, class: "btn btn-outline-light btn-sm" %>
            </div>
          </div>
        </div>
      </nav>
    <% end %>

    <% flash.each do |type, message| %>
      <div class="container-fluid px-3 px-lg-4 mt-3">
        <div class="alert <%= flash_class(type) %> mb-0"><%= message %></div>
      </div>
    <% end %>

    <%= yield %>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
